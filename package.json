{
  "name": "police-konoha",
  "version": "1.0.0",
  "description": "Base de donnees du Registre de la Police de Konoha",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:status": "node src/status-server.js",
    "start:legacy": "node JS/server.js",
    "backup": "node JS/backup.js",
    "backup:verify": "node scripts/check-backups.js",
    "backup:restore": "node scripts/restore-backup.js",
    "db:export": "node scripts/export-sqlite.js",
    "front:encoding:check": "node scripts/check-front-encoding.js",
    "front:encoding:repair": "node scripts/repair-front-encoding.js",
    "test": "node --test .\\tests\\*.test.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.2"
  }
}
